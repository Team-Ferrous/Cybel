{
  "name": "frontend",
  "version": "1.0.0",
  "description": "Cybel AI – The intelligent core behind AUTOMAT, Cybel AI is a cutting-edge artificial intelligence engine designed to understand, learn, and optimize your environment. It powers decision-making, task automation, and smart interactions, enabling AUTOMAT to act autonomously and intuitively in both home and office settings.",
  "main": "index.js",
  "scripts": {
    "beforePack": "wsl bash -l -c \"cd ../src && ./scripts/build_faiss_wsl.sh\"",
    "build_faiss_unix": "/scripts/build_faiss_unix.sh",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "electron-builder --win portable",
    "test:mac": "electron-builder --mac portable",
    "test:linux": "electron-builder --linux portable",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^23.6.0",
    "tailwindcss": "^4.2.1"
  },
  "build": {
    "appId": "com.teamferrous.cybel",
    "productName": "cybel",
    "npmRebuild": false,
    "asar": true,
    "files": [
      "**/*",
      "node_modules/faiss-node/**/*",
      "node_modules/hnswlib-node/**/*",
      ".env"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "useZip": false
    },
    "asarUnpack": [
      "**/*.node",
      "**/faiss-node/**",
      "**/hnswlib-node/**"
    ]
  },
  "dependencies": {
    "@ai-sdk/xai": "^3.0.67",
    "@huggingface/transformers": "^3.8.1",
    "@vectorize-io/hindsight-client": "^0.4.17",
    "ai": "^6.0.116",
    "crypto": "^1.0.1",
    "dialog": "^0.3.1",
    "dotenv": "^17.3.1",
    "electron-store": "^11.0.2",
    "faiss-node": "^0.5.1",
    "fs-extra": "^11.3.3",
    "googleapis": "171.4.0",
    "hnswlib-node": "^3.0.0",
    "node-fetch": "^3.3.2",
    "open": "^11.0.0",
    "openai": "^6.22.0",
    "python-shell": "^5.0.0",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  }
}
