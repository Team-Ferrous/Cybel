{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AES Traceability Record",
  "type": "object",
  "additionalProperties": true,
  "required": ["trace_id", "requirement_id", "code_refs", "test_refs", "verification_refs", "owner", "timestamp"],
  "anyOf": [
    {"required": ["design_ref"]},
    {"required": ["design_refs"]}
  ],
  "properties": {
    "trace_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "requirement_id": {"type": "string", "minLength": 1},
    "design_ref": {"type": "string", "minLength": 1},
    "design_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "code_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "test_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "verification_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "aal": {"type": "string", "enum": ["AAL-0", "AAL-1", "AAL-2", "AAL-3"]},
    "owner": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "minLength": 1},
    "changed_files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "evidence_bundle_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "source_path": {"type": "string", "minLength": 1},
    "section_path": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "line_start": {"type": "integer", "minimum": 1},
    "line_end": {"type": "integer", "minimum": 1},
    "statement": {"type": "string", "minLength": 1},
    "normalized_statement": {"type": "string", "minLength": 1},
    "modality": {"type": "string", "minLength": 1},
    "strength": {"type": "string", "minLength": 1},
    "polarity": {"type": "string", "minLength": 1},
    "graph_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "source_hash": {"type": "string", "minLength": 1}
  }
}
