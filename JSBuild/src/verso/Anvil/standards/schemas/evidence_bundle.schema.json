{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AES Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "change_id",
    "trace_id",
    "changed_files",
    "aal",
    "chronicle_snapshot",
    "chronicle_diff",
    "verification_report_path",
    "red_team_report_path",
    "review_signoffs",
    "waivers"
  ],
  "properties": {
    "bundle_id": {"type": "string", "minLength": 1},
    "change_id": {"type": "string", "minLength": 1},
    "trace_id": {"type": "string", "minLength": 1},
    "changed_files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "aal": {"type": "string", "enum": ["AAL-0", "AAL-1", "AAL-2", "AAL-3"]},
    "chronicle_snapshot": {"type": "string", "minLength": 1},
    "chronicle_diff": {"type": "string", "minLength": 1},
    "verification_report_path": {"type": "string", "minLength": 1},
    "red_team_report_path": {"type": "string", "minLength": 1},
    "review_signoffs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reviewer", "timestamp", "decision"],
        "properties": {
          "reviewer": {"type": "string", "minLength": 1},
          "timestamp": {"type": "string", "minLength": 1},
          "decision": {"type": "string", "enum": ["approved", "rejected", "pending"]}
        }
      }
    },
    "waivers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "author": {"type": "string", "minLength": 1},
    "evidence_class": {
      "type": "string",
      "enum": ["exploratory", "certification", "release"]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "runtime_gate_receipts": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "schema_validation_receipts": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
