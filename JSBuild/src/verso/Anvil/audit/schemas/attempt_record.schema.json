{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "native_qsg_audit.attempt_record.v2",
  "title": "Native QSG Audit Attempt Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "attempt_id",
    "model_id",
    "run_index",
    "warmup",
    "prompt_hash",
    "seed",
    "thread_config",
    "host",
    "sampling_config",
    "throughput",
    "latency",
    "coherence",
    "runtime",
    "provenance",
    "measurement",
    "status"
  ],
  "properties": {
    "run_id": {"type": "string"},
    "attempt_id": {"type": "string"},
    "model_id": {"type": "string"},
    "run_index": {"type": "integer"},
    "warmup": {"type": "boolean"},
    "lane_id": {"type": ["string", "null"]},
    "ablation_id": {"type": ["string", "null"]},
    "prompt_hash": {"type": "string"},
    "seed": {"type": "integer"},
    "thread_config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decode_threads",
        "batch_threads",
        "ubatch",
        "runtime_decode_threads",
        "runtime_batch_threads",
        "runtime_ubatch"
      ],
      "properties": {
        "decode_threads": {"type": ["integer", "null"]},
        "batch_threads": {"type": ["integer", "null"]},
        "ubatch": {"type": ["integer", "null"]},
        "runtime_decode_threads": {"type": ["integer", "null"]},
        "runtime_batch_threads": {"type": ["integer", "null"]},
        "runtime_ubatch": {"type": ["integer", "null"]}
      }
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "affinity_visible_threads",
        "runtime_affinity_visible_threads",
        "launch_affinity_cpus",
        "runtime_affinity_cpus",
        "physical_core_count",
        "logical_core_count",
        "p_core_count",
        "omp_max_threads",
        "worker_cpu_mask",
        "orchestrator_cpu_mask",
        "affinity_policy",
        "cpu_governor",
        "thp_mode"
      ],
      "properties": {
        "affinity_visible_threads": {"type": ["integer", "null"]},
        "runtime_affinity_visible_threads": {"type": ["integer", "null"]},
        "launch_affinity_cpus": {"type": "array", "items": {"type": "integer"}},
        "runtime_affinity_cpus": {"type": "array", "items": {"type": "integer"}},
        "physical_core_count": {"type": ["integer", "null"]},
        "logical_core_count": {"type": ["integer", "null"]},
        "p_core_count": {"type": ["integer", "null"]},
        "omp_max_threads": {"type": ["integer", "null"]},
        "worker_cpu_mask": {"type": "string"},
        "orchestrator_cpu_mask": {"type": "string"},
        "affinity_policy": {"type": "string"},
        "cpu_governor": {"type": "string"},
        "thp_mode": {"type": "string"}
      }
    },
    "sampling_config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "temperature",
        "top_p",
        "top_k",
        "min_p",
        "presence_penalty",
        "repetition_penalty"
      ],
      "properties": {
        "profile": {"type": ["string", "null"]},
        "temperature": {"type": ["number", "null"]},
        "top_p": {"type": ["number", "null"]},
        "top_k": {"type": ["integer", "null"]},
        "min_p": {"type": ["number", "null"]},
        "presence_penalty": {"type": ["number", "null"]},
        "repetition_penalty": {"type": ["number", "null"]}
      }
    },
    "throughput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wall_tokens_per_second", "prefill_tps", "decode_tps", "e2e_tps"],
      "properties": {
        "wall_tokens_per_second": {"type": "number"},
        "prefill_tps_raw": {"type": "number"},
        "prefill_tps": {"type": "number"},
        "effective_prefill_tps": {"type": "number"},
        "decode_tps": {"type": "number"},
        "e2e_tps": {"type": "number"}
      }
    },
    "latency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ttft_ms", "p50_ms", "p95_ms"],
      "properties": {
        "ttft_ms": {"type": "number"},
        "p10_ms": {"type": "number"},
        "p25_ms": {"type": "number"},
        "p50_ms": {"type": "number"},
        "p75_ms": {"type": "number"},
        "p95_ms": {"type": "number"},
        "p99_ms": {"type": "number"},
        "stddev_ms": {"type": "number"},
        "min_ms": {"type": "number"},
        "max_ms": {"type": "number"}
      }
    },
    "coherence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "issues", "raw_ok", "raw_issues"],
      "properties": {
        "ok": {"type": "boolean"},
        "issues": {"type": "array", "items": {"type": "string"}},
        "raw_ok": {"type": "boolean"},
        "raw_issues": {"type": "array", "items": {"type": "string"}}
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": {"type": "string"},
        "raw_text": {"type": "string"},
        "printable_ratio": {"type": ["number", "null"]},
        "repeated_8gram_ratio": {"type": ["number", "null"]}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_total_seconds",
        "runtime_prefill_seconds",
        "runtime_decode_seconds",
        "graph_stage_ms",
        "graph_stage_calls",
        "context_stabilizer_enabled",
        "context_stabilizer_mode",
        "strict_path_stable",
        "native_backend_abi_match",
        "grover_enabled",
        "coconut_enabled",
        "perf_event_access",
        "perf_event_access_reason",
        "python_hot_path_calls",
        "numpy_hot_path_calls",
        "python_attention_fallback_calls",
        "python_ssm_fallback_calls",
        "python_moe_fallback_calls",
        "llama_cpp_hot_path_calls",
        "batch_token_fallback_count",
        "drift_latest",
        "drift_mean",
        "drift_max",
        "drift_decay_ratio",
        "drift_damped_blocks",
        "drift_pruned_blocks",
        "drift_active_tokens",
        "drift_overhead_percent",
        "stabilizer_seconds",
        "stabilizer_calls",
        "drift_auto_downgrade_events"
      ],
      "properties": {
        "runtime_total_seconds": {"type": "number"},
        "runtime_prefill_seconds": {"type": "number"},
        "runtime_decode_seconds": {"type": "number"},
        "graph_stage_ms": {"type": "object"},
        "graph_stage_calls": {"type": "object"},
        "context_stabilizer_enabled": {"type": "boolean"},
        "context_stabilizer_mode": {"type": ["string", "null"]},
        "strict_path_stable": {"type": "boolean"},
        "native_backend_abi_match": {"type": "boolean"},
        "grover_enabled": {"type": "boolean"},
        "coconut_enabled": {"type": "boolean"},
        "perf_event_access": {"type": "boolean"},
        "perf_event_access_reason": {"type": "string"},
        "python_hot_path_calls": {"type": "integer", "minimum": 0},
        "numpy_hot_path_calls": {"type": "integer", "minimum": 0},
        "python_attention_fallback_calls": {"type": "integer", "minimum": 0},
        "python_ssm_fallback_calls": {"type": "integer", "minimum": 0},
        "python_moe_fallback_calls": {"type": "integer", "minimum": 0},
        "llama_cpp_hot_path_calls": {"type": "integer", "minimum": 0},
        "batch_token_fallback_count": {"type": "integer", "minimum": 0},
        "drift_latest": {"type": ["number", "null"]},
        "drift_mean": {"type": ["number", "null"]},
        "drift_max": {"type": ["number", "null"]},
        "drift_decay_ratio": {"type": ["number", "null"]},
        "drift_damped_blocks": {"type": ["integer", "null"], "minimum": 0},
        "drift_pruned_blocks": {"type": ["integer", "null"], "minimum": 0},
        "drift_active_tokens": {"type": ["integer", "null"], "minimum": 0},
        "drift_overhead_percent": {"type": ["number", "null"]},
        "stabilizer_seconds": {"type": ["number", "null"], "minimum": 0},
        "stabilizer_calls": {"type": ["integer", "null"], "minimum": 0},
        "drift_auto_downgrade_events": {"type": ["integer", "null"], "minimum": 0},
        "os_thread_migrations": {"type": ["integer", "null"], "minimum": 0},
        "os_last_cpu": {"type": ["integer", "null"]},
        "numa_strict": {"type": ["boolean", "null"]},
        "numa_affinity_mode": {"type": ["string", "null"]},
        "numa_hugepage": {"type": ["string", "null"]},
        "numa_bind_policy": {"type": ["string", "null"]},
        "numa_first_touch": {"type": ["boolean", "null"]},
        "graph_prefill_avg_ms": {"type": "number"},
        "graph_decode_avg_ms": {"type": "number"},
        "sample_avg_ms": {"type": "number"},
        "logits_processor_avg_ms": {"type": "number"},
        "penalty_avg_ms": {"type": "number"},
        "suppression_avg_ms": {"type": "number"},
        "scheduler_queue_wait_ms": {"type": "number"},
        "scheduler_iteration_ms": {"type": "number"},
        "hot_path_proof": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "architecture": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hidden_dim": {"type": "integer"},
        "num_layers": {"type": "integer"},
        "num_heads": {"type": "integer"},
        "num_kv_heads": {"type": "integer"},
        "head_dim": {"type": "integer"},
        "intermediate_dim": {"type": "integer"},
        "vocab_size": {"type": "integer"},
        "num_experts": {"type": "integer"},
        "top_k_experts": {"type": "integer"},
        "weight_qtype": {"type": "string"}
      }
    },
    "kernel_efficiency": {
      "type": "object",
      "additionalProperties": true
    },
    "feature_toggles": {
      "type": "object",
      "additionalProperties": true
    },
    "dataset_id": {"type": ["string", "null"]},
    "prompt_id": {"type": ["string", "null"]},
    "artifact_paths": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "perplexity": {"type": ["object", "null"]},
        "confidence": {"type": ["object", "null"]},
        "calibration": {"type": ["object", "null"]},
        "coherence": {"type": ["object", "null"]},
        "timecrystal_ablation": {"type": ["object", "null"]},
        "artifact_refs": {"type": ["object", "null"]}
      }
    },
    "parallel_decode": {"type": "boolean"},
    "speculative_decode": {"type": "boolean"},
    "generation_mode": {"type": "string"},
    "benchmark_label": {"type": "string"},
    "prompt_category": {"type": "string"},
    "temperature_band": {"type": "string"},
    "accepted_parallel_tokens": {"type": "integer", "minimum": 0},
    "rejected_parallel_tokens": {"type": "integer", "minimum": 0},
    "draft_source": {"type": "string"},
    "blockwise_convergence_rate": {"type": "number"},
    "quality_guard_triggered": {"type": "boolean"},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "native_build_id",
        "native_build_sha256",
        "loaded_native_library",
        "sanctioned_backend_path",
        "tokenizer_backend",
        "backend_module",
        "backend_module_library",
        "backend_module_loaded",
        "backend_module_marker_symbol",
        "backend_module_marker",
        "full_qsg_enabled",
        "native_isa_baseline",
        "native_backend_abi_match",
        "perf_event_access",
        "perf_event_access_reason",
        "host_access",
        "collect_hw_counters",
        "require_grover",
        "require_coconut",
        "autotune",
        "cwd",
        "argv",
        "started_at",
        "finished_at",
        "duration_ms",
        "stdout_sha256",
        "stderr_sha256",
        "benchmark_schema_version",
        "report_failure_count",
        "report_failure_keys"
      ],
      "properties": {
        "native_build_id": {"type": ["string", "null"]},
        "native_build_sha256": {"type": ["string", "null"]},
        "loaded_native_library": {"type": ["string", "null"]},
        "sanctioned_backend_path": {"type": ["string", "null"]},
        "tokenizer_backend": {"type": ["string", "null"]},
        "backend_module": {"type": ["string", "null"]},
        "backend_module_library": {"type": ["string", "null"]},
        "backend_module_loaded": {"type": "boolean"},
        "backend_module_marker_symbol": {"type": ["string", "null"]},
        "backend_module_marker": {"type": "integer"},
        "full_qsg_enabled": {"type": "boolean"},
        "native_isa_baseline": {"type": "string"},
        "native_backend_abi_match": {"type": "boolean"},
        "perf_event_access": {"type": "boolean"},
        "perf_event_access_reason": {"type": "string"},
        "host_access": {"type": "string"},
        "collect_hw_counters": {"type": "string"},
        "require_grover": {"type": "boolean"},
        "require_coconut": {"type": "boolean"},
        "autotune": {"type": "string"},
        "cwd": {"type": "string"},
        "argv": {"type": "array", "items": {"type": "string"}},
        "started_at": {"type": "string"},
        "finished_at": {"type": "string"},
        "duration_ms": {"type": "integer", "minimum": 0},
        "stdout_sha256": {"type": "string"},
        "stderr_sha256": {"type": "string"},
        "stdout_log": {"type": ["string", "null"]},
        "stderr_log": {"type": ["string", "null"]},
        "env_overrides": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        },
        "perf_stat_artifact": {"type": ["string", "null"]},
        "perf_c2c_artifact": {"type": ["string", "null"]},
        "numa_maps_artifact": {"type": ["string", "null"]},
        "benchmark_schema_version": {"type": "string"},
        "report_failure_count": {"type": "integer", "minimum": 0},
        "report_failure_keys": {"type": "array", "items": {"type": "string"}}
      }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid", "issues", "missing_signals"],
      "properties": {
        "valid": {"type": "boolean"},
        "issues": {"type": "array", "items": {"type": "string"}},
        "missing_signals": {"type": "array", "items": {"type": "string"}},
        "report_type": {"type": "string"},
        "perf_stat_artifact": {"type": "string"},
        "pmu": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "observed",
            "parse_error",
            "cycles",
            "instructions",
            "ipc",
            "cache_references",
            "cache_misses",
            "cache_miss_rate",
            "context_switches",
            "cpu_migrations",
            "page_faults"
          ],
          "properties": {
            "observed": {"type": "boolean"},
            "parse_error": {"type": "string"},
            "cycles": {"type": ["number", "null"]},
            "instructions": {"type": ["number", "null"]},
            "ipc": {"type": ["number", "null"]},
            "cache_references": {"type": ["number", "null"]},
            "cache_misses": {"type": ["number", "null"]},
            "cache_miss_rate": {"type": ["number", "null"]},
            "context_switches": {"type": ["number", "null"]},
            "cpu_migrations": {"type": ["number", "null"]},
            "page_faults": {"type": ["number", "null"]}
          }
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["return_code", "ok", "issues"],
      "properties": {
        "return_code": {"type": "integer"},
        "ok": {"type": "boolean"},
        "issues": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
